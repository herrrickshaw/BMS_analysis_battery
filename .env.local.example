# GROW API Credentials (copy to .env.local and fill in real values - .env.local is gitignored)
GROW_API_KEY=your-grow-api-key-here
GROW_API_SECRET=your-grow-api-secret-here

# AI Advisor: chat agent + daily recommendation brief (Groq primary, Gemini fallback)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Deutsche Börse A7 market data feed
DEUTSCHE_BOERSE_A7_KEY=your-deutsche-boerse-a7-key-here

# FRED (Federal Reserve Economic Data) -- free registration at
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key-here
