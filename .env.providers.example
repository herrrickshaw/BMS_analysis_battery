# Copy this file to .env.providers, fill in your keys, then run:
#   set -a && source .env.providers && set +a
# before starting the backend.

# ── Alpha Vantage ─────────────────────────────────────────────────────────────
# Free tier: 25 req/day  |  https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── Polygon.io ────────────────────────────────────────────────────────────────
# Free: 5 req/min delayed  |  https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# ── IEX Cloud ─────────────────────────────────────────────────────────────────
# Credit-based  |  https://iexcloud.io/cloud-login#/register
IEX_TOKEN=
# IEX_BASE_URL=https://cloud.iexapis.com/stable   # default

# ── Tradier ───────────────────────────────────────────────────────────────────
# Developer sandbox (free)  |  https://developer.tradier.com/user/sign_up
TRADIER_API_KEY=
# TRADIER_BASE_URL=https://api.tradier.com/v1   # default (use https://sandbox.tradier.com/v1 for sandbox)

# ── Quandl / Nasdaq Data Link ─────────────────────────────────────────────────
# https://data.nasdaq.com/sign-up
NASDAQ_DATA_LINK_API_KEY=

# ── Currencylayer ─────────────────────────────────────────────────────────────
# Free: 100 req/month  |  https://currencylayer.com/signup
CURRENCYLAYER_ACCESS_KEY=

# ── Interactive Brokers ───────────────────────────────────────────────────────
# Requires IB Gateway or TWS running locally
# Paper trading port: 7497  |  Live trading port: 7496
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# ── TradingView ───────────────────────────────────────────────────────────────
# Optional — works anonymously with limited history
# Provide credentials for full history access
TRADINGVIEW_USERNAME=
TRADINGVIEW_PASSWORD=
