{
  "description": "Export analysis project with markitdown data preprocessing",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./markitdown-preprocessor.py",
            "statusMessage": "Preprocessing data inputs with markitdown...",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
